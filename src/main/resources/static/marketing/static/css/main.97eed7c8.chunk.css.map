body {
  background-color: #1b1d2f;
  /* background-color: #242a3c; */
  font-family: 'Roboto', sans-serif;
}
.store_btn {
  margin-right: 10px;
}
.store_btn img {
  max-height: 50px;
}
nav.navbar {
 background-color: #242a3c;
 padding: 0;
 /* background-color: #1B1D2F; */
 /* border-bottom: 1px solid #aaa3; */
}
#main_nav .nav-link {
  color: #fff;
}
#main_nav .nav-item {
  min-width: 100px;
  text-align: center;
}
.navbar-brand, .navbar-brand:active, .navbar-brand:focus, .navbar-brand:visited, .navbar-brand:hover {
  color: #fff;
}
#main_jumbo {
  /* background-image: url('/static/globe.jpg'); */
  background-color: #1b1d2f;
  background-position: top;
  height: 650px;
  position: relative;
}
#main_jumbo::before {
  content: '';
  position: absolute;
  top: 0; left: 0; bottom: 0; right: 0;
  background-color: #242a3caa;
  z-index: -1;
}
#main_jumbo .container, #main_jumbo .row {
  height: 100%;
}
#main_jumbo .row .col-lg-6 {
  display: flex;
  align-items: center;
  justify-content: flex-end;
}
#main_jumbo article {
  z-index: 1;
  color: #fff;
  display: block;
}
#main_jumbo article h1 {
  color: #fff;
}
#main_jumbo article p {
  color: #fff;
}
#main_jumbo div#_globeLoading {
  height: 100%;
  width: 100%;
  display: flex;
  justify-content: center;
  align-items: center;
}
#main_jumbo div#_globeLoading p {
  color: #fff;
}
#phone  {
  max-height: 400px;
}
div.sft-feature {
  text-align: center;
  /* box-shadow: 0px 0px 10px #111a; */
  border: 1px solid #111a;
  border-radius: 10px;
  padding: 20px;
  margin-top: -40px;
  z-index: 2;
  position: relative;
  background-color: #242a3c;
  margin-bottom: 50px;
}
div.sft-feature span {
  color: #E76F51;
  font-size: 4rem;
  display: block;
}
div.sft-feature h4 {
  color: #fff;
}
div.sft-feature p {
  color: #aaa;
}

@media only screen and (max-width: 420px) {
  #main_jumbo article {
      text-align: center;
  }
  .store_btn img {
      margin-top: 20px;
  }
}